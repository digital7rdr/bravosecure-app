# ─── Supabase (LOCAL dev — from `npx supabase status`) ─────────────
# After `npx supabase start`, copy this file to `.env` and fill in the
# real values printed by the CLI. API URL is stable across boots; anon
# key is stable for a given config.toml + migrations set.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_local_anon_key

# ─── API endpoints ──────────────────────────────────────────────────
# Android emulator reaches host via 10.0.2.2; iOS sim uses localhost.
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3001
EXPO_PUBLIC_MSG_BASE_URL=http://10.0.2.2:3100

# ─── Feature flags (mobile, build-time) ─────────────────────────────
# Department Chat v2 (provider↔CPO attendance verification + incident
# reporting). Default OFF; set true to enable the dark-launched module.
# Pair with DEPT_CHAT_V2_ENABLED=true on the auth-service.
EXPO_PUBLIC_DEPT_CHAT_V2=false

# ─── Twilio (server-only — never prefixed EXPO_PUBLIC_) ─────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_CONVERSATIONS_SERVICE_SID=ISxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Agora ──────────────────────────────────────────────────────────
EXPO_PUBLIC_AGORA_APP_ID=your_agora_app_id

# ─── Stripe (publishable = client; secret = server-only) ────────────
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google Maps ────────────────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─── Messenger-service (server-only, apps/messenger-service) ───────
# MUST match auth-service's JWT_ACCESS_SECRET — tokens minted by
# auth-service are verified by messenger-service without a shared
# revocation store in Phase 1 (M10 adds Redis-backed JTI lookup).
JWT_ACCESS_SECRET=change-me-long-random-32-plus-char-string
JWT_ISSUER=auth-service
JWT_AUDIENCE=bravo-api
WS_PATH=/ws
WS_HEARTBEAT_MS=30000
# B-05 — pong grace window (socket.io pingTimeout). MUST stay >= 25000: at 10000
# a late pong under Contabo/TURN latency spikes reaped the socket and kicked every
# participant of a live call at once. The code default (configuration.ts) is 25000;
# this template previously shipped 10000 and would silently override the fix on any
# deploy that copied it verbatim. See sqa.md B-05.
WS_HEARTBEAT_GRACE=25000
REDIS_URL=redis://127.0.0.1:6379
RELAY_DWELL_SECONDS=2592000
RELAY_MAX_PULL_LIMIT=100
RELAY_MAX_CIPHERTEXT_BYTES=262144

# ─── M10 File Vault MFA ─────────────────────────────────────────────
# Action-token secret — MUST match auth-service's JWT_ACTION_SECRET.
# Defaults to JWT_ACCESS_SECRET if unset (matches auth-service default).
JWT_ACTION_SECRET=
JWT_ACTION_AUDIENCE=bravo-action
VAULT_PRESIGN_TTL_SECONDS=60
VAULT_MFA_MAX_AGE_SEC=300
VAULT_MFA_PURPOSES=vault-access,biometric-verified,totp-verified

# ─── BE-4.2 TURN credential issuance (coturn REST API) ─────────────
# Shared secret — MUST match coturn's `static-auth-secret`.
# Rotate coturn + this env together.
TURN_STATIC_AUTH_SECRET=
TURN_TTL_SECONDS=86400
# Comma-separated coturn URLs. SHIP BOTH UDP AND TCP transports — many
# corporate / hotel / mobile-data networks block outbound UDP to non-443
# ports, and TCP-only is the only path that reaches coturn from those
# networks. Same-LAN calls don't need TURN at all (host candidates
# connect directly), so cross-WiFi reliability is the whole reason this
# service exists. Default points at the staging EC2; override per region.
TURN_URLS=turn:94.136.184.52:3478?transport=udp,turn:94.136.184.52:3478?transport=tcp
# Public STUN URLs prepended to the TURN list in /webrtc/turn-credentials
# responses. STUN gathers srflx candidates without auth and lets many
# same-ISP NAT pairs connect without ever touching the relay. Also a
# graceful fallback when TURN is misconfigured. Comma-separated.
TURN_STUN_URLS=stun:stun.l.google.com:19302

# ─── BE-2.2 Sender cert TTL (24h per WBS) ──────────────────────────
SENDER_CERT_TTL_SECONDS=86400

# ─── Sealed Sender certs (auth-service signs, clients verify) ──────
# XEd25519 over Curve25519 — the same primitive libsignal uses for
# SignedPreKey signatures. Both mobile (RN) and ops-console (browser)
# verify with `@privacyresearch/curve25519-typescript`, so no extra
# polyfill is needed for Sealed Sender on either platform.
#
# Generate a fresh keypair once and distribute:
#   node -e "const {AsyncCurve25519Wrapper}=require('@privacyresearch/curve25519-typescript'); \
#            const w=new AsyncCurve25519Wrapper(); \
#            const s=require('crypto').randomBytes(32); \
#            w.keyPair(s.buffer.slice(s.byteOffset,s.byteOffset+32)).then(k=>console.log({\
#              priv:Buffer.from(k.privKey).toString('base64'), \
#              pub:Buffer.from(k.pubKey).toString('base64')}))"
#
# Private half → auth-service .env (SENDER_CERT_PRIVATE_KEY_B64).
# Public half  → every client build (EXPO_PUBLIC_*, NEXT_PUBLIC_*).
SENDER_CERT_ISSUER=auth-service
SENDER_CERT_TTL_SECONDS=86400
SENDER_CERT_PRIVATE_KEY_B64=
# Public key bundled with the RN client at build time:
EXPO_PUBLIC_SENDER_CERT_PUBLIC_KEY_B64=
# Public key bundled with ops-console at build time (Next.js):
NEXT_PUBLIC_SENDER_CERT_PUBLIC_KEY_B64=

# ─── Media attachments (R2 / S3-compatible) ─────────────────────────
# R2 endpoint: https://<accountid>.r2.cloudflarestorage.com
# For local dev against minio: http://127.0.0.1:9000
MEDIA_S3_ENDPOINT=
MEDIA_S3_BUCKET=bravo-messenger-media
MEDIA_S3_REGION=auto
MEDIA_S3_ACCESS_KEY_ID=
MEDIA_S3_SECRET_ACCESS_KEY=
MEDIA_PRESIGN_TTL_SECONDS=300
MEDIA_MAX_UPLOAD_BYTES=52428800

# ─── Encrypted backup (messenger-service) ──────────────────────────
# Service-role key — bypasses Supabase RLS so messenger-service can
# read/write the messages_backup, conversation_backups, and
# identity_backups tables on behalf of any authenticated user.
# NEVER expose this to the client. The mobile app talks ONLY to
# messenger-service for backup ops; supabase-js is not used here.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Brute-force throttle on identity unwrap (matches WhatsApp's HSM-
# backed throttle: 5 attempts then 1h cool-down).
BACKUP_MAX_FAILED_ATTEMPTS=5
BACKUP_LOCKOUT_SECONDS=3600
# Max rows per POST /backup/messages batch upload. NOTE: the DTO hard
# ceiling (500, dto/backup.dto.ts MAX_MESSAGES_PER_BATCH) is the true
# wire limit — this var can only LOWER the accepted batch, never raise it.
BACKUP_MAX_MESSAGE_BATCH=500
# H-11 — per-user row ceiling across messages_backup + conversation_backups
# (no retention sweep yet — Phase-2). Best-effort; over-cap writes → 507.
BACKUP_MAX_MESSAGE_ROWS_PER_USER=500000
# P0-1 verify protocol TTLs (seconds): nonce = password entry + argon2id
# derive window; token = short /verify → /bundle window.
BACKUP_VERIFY_NONCE_TTL_SEC=300
BACKUP_VERIFY_TOKEN_TTL_SEC=120

# ─── Firebase (native push) ─────────────────────────────────────────
# Place google-services.json   in android/app/
# Place GoogleService-Info.plist in ios/BravoSecure/
