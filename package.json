  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=20"
    ],
    "*.{js,jsx,json,md,yml,yaml}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "jest": {
    "projects": [
      {
        "displayName": "app",
        "preset": "react-native",
        "setupFilesAfterEnv": [
          "<rootDir>/jest.setup.app.js"
        ],
        "transformIgnorePatterns": [
          "node_modules/(?!((jest-)?react-native|@react-native(-community)?|@react-native/.*|expo-modules-core|@react-navigation/.*|@testing-library/react-native|immer|zustand)/)"
        ],
        "testPathIgnorePatterns": [
          "<rootDir>/src/modules/messenger/__tests__/",
          "<rootDir>/packages/messenger-core/__tests__/",
          "<rootDir>/src/screens/booking/__tests__/",
          "<rootDir>/src/screens/agent/__tests__/",
          "<rootDir>/apps/",
          "<rootDir>/worldmonitor/"
        ]
      },
      {
        "displayName": "messenger-crypto",
        "testEnvironment": "node",
        "testMatch": [
          "<rootDir>/src/modules/messenger/__tests__/**/*.test.ts",
          "<rootDir>/packages/messenger-core/__tests__/**/*.test.ts"
        ],
        "moduleNameMapper": {
          "^react-native-argon2$": "<rootDir>/src/modules/messenger/__tests__/__mocks__/react-native-argon2.ts",
          "^react-native-quick-crypto$": "<rootDir>/src/modules/messenger/__tests__/__mocks__/react-native-quick-crypto.ts",
          "^@bravo/messenger-core$": "<rootDir>/packages/messenger-core/src",
          "^@bravo/messenger-core/(.*)$": "<rootDir>/packages/messenger-core/src/$1"
        },
        "transformIgnorePatterns": [
          "/node_modules/(?!(@noble/hashes)/)"
        ],
        "transform": {
          "^.+\\.(ts|tsx|js|jsx)$": [
            "babel-jest",
            {
              "presets": [
                [
                  "@babel/preset-env",
                  {
                    "targets": {
                      "node": "current"
                    }
                  }
                ],
                "@babel/preset-typescript"
              ]
            }
          ]
        },
        "setupFiles": [
          "<rootDir>/packages/messenger-core/__tests__/setup.ts"
        ]
      },
      {
        "displayName": "booking",
        "testEnvironment": "node",
        "testMatch": [
          "<rootDir>/src/screens/booking/__tests__/**/*.test.ts",
          "<rootDir>/src/screens/agent/__tests__/**/*.test.ts"
        ],
        "transform": {
          "^.+\\.(ts|tsx|js|jsx)$": [
            "babel-jest",
            {
              "presets": [
                [
                  "@babel/preset-env",
                  {
                    "targets": {
                      "node": "current"
                    }
                  }
                ],
                "@babel/preset-typescript"
              ]
            }
          ]
        }
      }
    ]
  },
  "op-sqlite": {
    "sqlcipher": true
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-fs",
          "react-native-geolocation-service",
          "react-native-vector-icons"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "engines": {
    "node": ">=18"
  }
}
