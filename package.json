    "eas:whoami": "npx eas whoami",
    "eas:init": "npx eas init",
    "eas:build:staging": "npx eas build --profile preview-staging --platform android",
    "eas:build:local": "npx eas build --profile preview-local --platform android",
    "eas:build:both": "npx eas build --profile preview-staging --platform android --non-interactive && npx eas build --profile preview-local --platform android --non-interactive",
    "eas:build:ios:staging": "npx eas build --profile preview-staging --platform ios",
    "eas:build:ios:local": "npx eas build --profile preview-local --platform ios",
    "eas:build:ios:device": "npx eas build --profile preview-staging-device --platform ios",
    "eas:builds": "npx eas build:list --platform android",
    "release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release-apk.ps1",
    "test": "jest",
    "test:crypto": "jest --selectProjects messenger-crypto",
    "test:changed": "jest --changedSince=origin/main --passWithNoTests",
    "test:coverage": "jest --coverage --coverageReporters=json-summary --coverageReporters=text",
    "typecheck": "tsc --noEmit",
    "tsc:rebaseline": "node scripts/tsc-rebaseline.mjs",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "deadcode": "npx knip",
    "audit:high": "npm audit --audit-level=high --omit=dev",
    "mutation:crypto": "stryker run stryker.crypto.config.mjs",
    "size": "size-limit",
    "sbom": "cyclonedx-npm --output-file sbom.cdx.json --output-format JSON",
    "flake:crypto": "node scripts/flake-detect.mjs messenger-crypto",
    "ci:local": "npm run typecheck && npm run lint && npm run test:changed",
    "ci:full": "npm run typecheck && npm run lint && npm test && npm run deadcode",
    "adb:watch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/adb-reverse-watcher.ps1",
    "emu": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-emulator.ps1",
    "android:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-android-env.ps1",
    "prepare": "husky",
    "postinstall": "patch-package"
  },
