# ─────────────────────────────────────────────────────────────────────
# TEMPLATE — copy to `.env.staging.local` for local Metro hot reload
# against the Contabo staging backend (behind Caddy).
#
#   cp .env.staging.local.example .env.staging.local
#   npm run start:staging:hot      # Metro on your PC, Fast Refresh
#   npm run android:staging:hot    # build+install, JS served from Metro
#
# The real `.env.staging.local` is gitignored. A plain `npm start` still
# uses .env (127.0.0.1 local backend) — these scripts load this file
# explicitly via dotenv-cli, so local-localhost and staging-hot coexist.
# All values are EXPO_PUBLIC_* (client-public); the Supabase anon key is
# the publishable key (no service-role secret).
# ─────────────────────────────────────────────────────────────────────

# Contabo staging backend (Caddy / sslip.io TLS):
EXPO_PUBLIC_API_BASE_URL=https://auth.94-136-184-52.sslip.io
EXPO_PUBLIC_MSG_BASE_URL=https://relay.94-136-184-52.sslip.io

# Supabase staging cloud project (anon/publishable key):
EXPO_PUBLIC_SUPABASE_URL=https://qkkfkicgoncxslbwhyhz.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<paste the staging anon key — see .env.production or eas.json>

# Mapbox (client-public pk token; URL-restrict it in the Mapbox dashboard):
EXPO_PUBLIC_MAPBOX_TOKEN=<paste the pk. token — see .env.production or eas.json>
