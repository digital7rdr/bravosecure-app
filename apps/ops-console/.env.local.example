# Bravo Ops Console — environment
# Copy to .env.local and fill in real values.

# Backend API (NestJS auth-service with Ops module)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Mapbox access token (https://account.mapbox.com/)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...your-token-here

# Mapbox dark style — Command Navy looks great on Dark Matter / Navigation Night
NEXT_PUBLIC_MAPBOX_STYLE=mapbox://styles/mapbox/navigation-night-v1

# Polling intervals (ms)
NEXT_PUBLIC_DASHBOARD_POLL_MS=5000
NEXT_PUBLIC_MISSION_POLL_MS=2000

# XEd25519 (Curve25519) sender-cert public key, base64.
# Must match the SENDER_CERT_PRIVATE_KEY_B64 keypair on auth-service.
NEXT_PUBLIC_SENDER_CERT_PUBLIC_KEY_B64=
