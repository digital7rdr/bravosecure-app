NODE_ENV=development
PORT=3100
JWT_ACCESS_SECRET=
JWT_ACTION_SECRET=
JWT_ISSUER=auth-service
JWT_AUDIENCE=bravo-api
JWT_ACTION_AUDIENCE=bravo-action
REDIS_URL=redis://127.0.0.1:6379
RELAY_DWELL_SECONDS=2592000
RELAY_MAX_PULL_LIMIT=100
RELAY_MAX_CIPHERTEXT_BYTES=262144
TURN_STATIC_AUTH_SECRET=
TURN_TTL_SECONDS=86400
# UDP+TCP both — see comment in apps/messenger-service/src/config/configuration.ts.
# 127.0.0.1 is ONLY valid for emulator dev with `adb reverse tcp:3478 tcp:3478`;
# real devices on a LAN must hit the host's LAN IP (e.g. 192.168.1.x).
TURN_URLS=turn:127.0.0.1:3478?transport=udp,turn:127.0.0.1:3478?transport=tcp
TURN_STUN_URLS=stun:stun.l.google.com:19302
WS_HEARTBEAT_MS=30000
# B-05 — pong grace window (socket.io pingTimeout). MUST stay >= 25000:
# at 10000 a late pong under Contabo/TURN latency spikes reaped the socket
# and kicked every participant of a live call at once (the QA "all calls
# drop after 2–14 min" finding). The code default is already 25000; this
# example previously shipped 10000 and would silently override the fix on
# any deploy that copied it verbatim.
WS_HEARTBEAT_GRACE=25000
MEDIA_S3_ENDPOINT=
MEDIA_S3_BUCKET=bravo-messenger-media
MEDIA_S3_REGION=auto
MEDIA_S3_ACCESS_KEY_ID=
MEDIA_S3_SECRET_ACCESS_KEY=
