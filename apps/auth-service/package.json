{
  "name": "@bravo/auth-service",
  "version": "0.1.0",
  "description": "Bravo Secure — Auth microservice (NestJS, port 3001)",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:integration": "jest --config jest.integration.config.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/throttler": "^6.2.1",
    "@privacyresearch/curve25519-typescript": "^0.0.12",
    "@types/multer": "^2.1.0",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "kafkajs": "^2.2.4",
    "multer": "^2.1.1",
    "otpauth": "^9.4.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "twilio": "^5.5.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "jest": "^29.7.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.spec.(t|j)s",
      "!**/main.ts",
      "!**/*.module.ts",
      "!**/*.dto.ts",
      "!**/config/configuration.ts",
      "!**/*.controller.ts",
      "!**/database/database.service.ts",
      "!**/redis/redis.service.ts",
      "!**/kafka/audit.service.ts",
      "!**/common/decorators/*.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "lines": 90,
        "functions": 90,
        "branches": 72
      }
    }
  }
}
