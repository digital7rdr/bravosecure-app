PORT=3001
NODE_ENV=development

# Postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Redis  (Windows: Hyper-V blocks 6379, use 7379)
REDIS_URL=redis://127.0.0.1:7379

# JWT
JWT_ACCESS_SECRET=dev-access-secret-do-not-use-in-prod-xxxxxxxxxxxxxxxx
JWT_ACTION_SECRET=dev-action-secret-do-not-use-in-prod-xxxxxxxxxxxxxxxx
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# OTP
OTP_LENGTH=6
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_DEV_RETURN_CODE=true        # NEVER true in prod

# Twilio (blank = uses dev bypass above)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# TOTP  —  64 hex chars = 32 bytes AES-256 key
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Production: load from HashiCorp Vault
TOTP_ENCRYPTION_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
TOTP_ISSUER=Bravo Secure

# Kafka  (blank = stdout-only stub in dev)
KAFKA_BROKERS=
KAFKA_AUDIT_TOPIC=audit-events

# Biometric
BIOMETRIC_DEV_BYPASS=true
GOOGLE_PLAY_INTEGRITY_KEY=
ANDROID_PACKAGE_NAME=com.bravosecure
APPLE_TEAM_ID=
APPLE_DEVICE_CHECK_KEY_ID=
APPLE_DEVICE_CHECK_P8_KEY=

# Rate limiting
RATE_LIMIT_AUTH_PER_HOUR=5

# Sealed-sender signing key (XEd25519 / Curve25519). Generate with:
#   node -e "const w=new (require('@privacyresearch/curve25519-typescript').AsyncCurve25519Wrapper)();const s=require('crypto').randomBytes(32);w.keyPair(s.buffer.slice(s.byteOffset,s.byteOffset+32)).then(k=>console.log({priv:Buffer.from(k.privKey).toString('base64'),pub:Buffer.from(k.pubKey).toString('base64')}))"
# Distribute the matching public key to mobile + ops-console as
# EXPO_PUBLIC_SENDER_CERT_PUBLIC_KEY_B64 / NEXT_PUBLIC_SENDER_CERT_PUBLIC_KEY_B64.
SENDER_CERT_PRIVATE_KEY_B64=
SENDER_CERT_TTL_SECONDS=86400
SENDER_CERT_ISSUER=auth-service

# Feature flags
# Department Chat v2 (provider↔CPO attendance verification + incident reporting).
# Default OFF; set true to enable the dark-launched module for an environment.
# Read via ConfigService.get('featureFlags.deptChatV2').
DEPT_CHAT_V2_ENABLED=false
