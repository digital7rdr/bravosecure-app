-    api 'org.jitsi:webrtc:124.+'
+    // Bravo patch: swap Jitsi's stock libwebrtc 124.x for Stream's
+    // libwebrtc 1.3.x build. The Stream artifact ships
+    // org.webrtc.FrameCryptor / FrameCryptorFactory /
+    // FrameCryptorKeyProvider — the LiveKit-style frame-level AES-GCM
+    // E2E cipher (see docs/ARCHITECTURE_AMENDMENT_SFRAME.md for the
+    // client-signed architecture amendment). Jitsi 124.x ships only
+    // the older opaque FrameEncryptor / FrameDecryptor interfaces
+    // which can't be implemented from Kotlin / JS. The Stream build
+    // is a drop-in replacement at the org.webrtc.* package level;
+    // every existing rn-webrtc call site compiles unchanged. Pinned
+    // to a specific minor to avoid surprise libwebrtc upgrades.
+    api 'io.getstream:stream-webrtc-android:1.3.10'
     implementation "androidx.core:core:1.7.0"
 }
