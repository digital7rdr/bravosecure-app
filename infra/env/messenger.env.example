# ──────────────────────────────────────────────────────────────────────
# /etc/bravo/messenger.env  (template — copy to that path, fill secrets,
#                            chmod 0640, chown root:root)
#
# Loaded by bravo-messenger.service via `--env-file`.
#
# Phase 5.1 dependency: REDIS_URL MUST match /etc/bravo/auth.env so the
# `mission:events` pub/sub channel fans out cross-process. JWT_ACCESS_SECRET
# MUST also match — the messenger ticket is a 5-min access JWT signed by
# auth-service and verified here.
# ──────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3100

# ── WebSocket heartbeat (socket.io ping/pong) ────────────────────────
# B-05 — WS_HEARTBEAT_GRACE feeds socket.io pingTimeout (redis-io.adapter.ts).
# MUST be >= 25000 in production: at 10000 a late pong under Contabo/TURN latency
# spikes (measured max ~2.6s RTT, ~10% loss) reaped the socket and kicked every
# participant of a live call at the same heartbeat cycle. The image default is
# already 25000; set it explicitly here so /etc/bravo/messenger.env is correct and
# self-documenting regardless of the image default. See sqa.md B-05.
WS_HEARTBEAT_MS=30000
WS_HEARTBEAT_GRACE=25000

# ── Redis (shared with auth-service) ─────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── JWT (shared secret with auth-service) ────────────────────────────
JWT_ACCESS_SECRET=<must-match-auth.env>

# ── Postgres (only if the relay needs it; many setups run without) ───
# DATABASE_URL=

# ── Sender cert verification ─────────────────────────────────────────
# Audit reference: sealed-sender v2 sender-cert verification. The
# public key is pinned in the mobile + ops-console builds; the
# private key lives only on auth-service to issue certs.
SENDER_CERT_PUBLIC_KEY_B64=<base64-curve25519-pubkey-pinned-from-auth-service>

# ── Audit fix 5.4 — Sentry (optional) ────────────────────────────────
SENTRY_DSN=

# ── TURN / STUN for WebRTC ───────────────────────────────────────────
TURN_STATIC_AUTH_SECRET=<openssl-rand-base64-32>
TURN_TTL_SECONDS=86400
TURN_URLS=turn:turn.example.com:3478
TURN_STUN_URLS=stun:stun.l.google.com:19302

# ── SFU (group calls) ────────────────────────────────────────────────
SFU_WORKERS=0
SFU_WORKER_LOG_LEVEL=warn
SFU_RTC_MIN_PORT=40000
SFU_RTC_MAX_PORT=49999
SFU_LISTEN_IP=0.0.0.0
SFU_ANNOUNCED_IP=

# ── Backup / file vault ──────────────────────────────────────────────
# L-7 — placeholder only. NEVER commit a real project ref here. Copy the
# actual URL into /etc/bravo/messenger.env on the host (chmod 0640).
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt-from-supabase-settings-api>

# ── Encrypted backup throttle / quota / verify TTLs ──────────────────
# Defaults MATCH apps/messenger-service/src/config/configuration.ts.
# Raising BACKUP_MAX_MESSAGE_BATCH above the DTO hard ceiling (500, in
# dto/backup.dto.ts MAX_MESSAGES_PER_BATCH) has NO effect — the DTO cap
# is the true wire limit; this env var can only LOWER the accepted batch.
BACKUP_MAX_FAILED_ATTEMPTS=5
BACKUP_LOCKOUT_SECONDS=3600
BACKUP_MAX_MESSAGE_BATCH=500
# H-11 — per-user row ceiling across messages_backup + conversation_backups
# (no retention sweep yet — Phase-2). Best-effort; over-cap writes → 507.
BACKUP_MAX_MESSAGE_ROWS_PER_USER=500000
# P0-1 verify protocol TTLs (seconds): nonce covers password entry +
# argon2id derive; token is the short /verify → /bundle window.
BACKUP_VERIFY_NONCE_TTL_SEC=300
BACKUP_VERIFY_TOKEN_TTL_SEC=120

# ── Media S3 (file vault) ────────────────────────────────────────────
MEDIA_S3_ENDPOINT=
MEDIA_S3_BUCKET=bravo-messenger-media
MEDIA_S3_REGION=auto
MEDIA_S3_ACCESS_KEY_ID=
MEDIA_S3_SECRET_ACCESS_KEY=
MEDIA_PRESIGN_TTL_SECONDS=300
