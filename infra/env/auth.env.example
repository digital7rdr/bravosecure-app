# ──────────────────────────────────────────────────────────────────────
# /etc/bravo/auth.env  (template — copy to that path, fill secrets,
#                      chmod 0640, chown root:root)
#
# Loaded by bravo-auth.service via `--env-file`. Lines starting with
# `#` are comments. Do NOT quote values; docker --env-file does NOT
# strip surrounding quotes (it treats them as part of the value).
#
# Sources for each value:
#   - DATABASE_URL              → Supabase Project Settings → Database → Connection (use the pooler URL for serverless connections)
#   - REDIS_URL                 → wherever the EC2 host's Redis lives (MUST match messenger.env)
#   - JWT_ACCESS_SECRET         → generate once via `openssl rand -base64 64`. MUST match messenger.env (sealed-sender + ticket verification).
#   - TWILIO_*                  → Twilio console (Verify service SID + auth token)
#   - STRIPE_*                  → Stripe dashboard (test mode in staging)
#   - SENTRY_DSN                → Sentry project → Settings → Client Keys (audit fix 5.4)
#   - CORS_ALLOWED_ORIGINS      → comma-separated; in staging this is the Vercel preview alias
# ──────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3001

# ── Postgres (Supabase) ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.qkkfkicgoncxslbwhyhz:<PASSWORD>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ── Redis (shared with messenger-service) ─────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── JWT ───────────────────────────────────────────────────────────────
# Audit fix 0.4 — shared with messenger-service so the messenger-ticket
# (5-min access JWT) verifies against the same secret.
JWT_ACCESS_SECRET=<replace-with-output-of-openssl-rand-base64-64>
JWT_ACTION_SECRET=<replace-with-output-of-openssl-rand-base64-64>
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── Audit fix 1.4 — strict validation ────────────────────────────────
# Flip to 'true' AFTER confirming the staging canary doesn't see a 400
# spike from stale mobile builds sending extra fields.
STRICT_VALIDATION=false

# ── Audit fix 1.6 — CORS ─────────────────────────────────────────────
# Comma-separated allowed origins. Empty + NODE_ENV=production throws
# on boot (main.ts:84 — fail-closed). For staging this is the ops
# console Vercel preview alias.
CORS_ALLOWED_ORIGINS=https://ops-staging.bravosecure.app

# ── OTP / Twilio ─────────────────────────────────────────────────────
OTP_LENGTH=6
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_DEV_RETURN_CODE=false
OTP_DEV_BYPASS=false
TWILIO_ACCOUNT_SID=<AC…>
TWILIO_AUTH_TOKEN=<…>
TWILIO_FROM=+1<…>
TWILIO_VERIFY_SID=VA<…>

# ── TOTP encryption (audit reference: TOTP module) ───────────────────
# 64-char hex (32 bytes). Generate via `openssl rand -hex 32`.
TOTP_ENCRYPTION_KEY=<64-char-hex>
TOTP_ISSUER=Bravo Secure

# ── Biometric device-check (mobile attestation) ──────────────────────
BIOMETRIC_DEV_BYPASS=false
GOOGLE_PLAY_INTEGRITY_KEY=
ANDROID_PACKAGE_NAME=com.bravosecure
APPLE_TEAM_ID=
APPLE_DEVICE_CHECK_KEY_ID=
APPLE_DEVICE_CHECK_P8_KEY=

# ── Kafka (optional in staging) ──────────────────────────────────────
KAFKA_BROKERS=
KAFKA_AUDIT_TOPIC=audit-events

# ── Audit fix 5.4 — Sentry ───────────────────────────────────────────
# Leave blank to disable. The shim no-ops when this is unset.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

# ── Stripe (Lite payments) ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_<…>
STRIPE_WEBHOOK_SECRET=whsec_<…>

# ── Supabase (for service-role calls from server) ────────────────────
SUPABASE_URL=https://qkkfkicgoncxslbwhyhz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt-from-supabase-settings-api>

# ── Sender cert (messenger E2EE) ─────────────────────────────────────
SENDER_CERT_ISSUER=auth-service
