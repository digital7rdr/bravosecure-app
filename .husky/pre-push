#!/usr/bin/env sh
# Pre-push gate — runs on every `git push` before the push goes out.
#
# Stricter than pre-commit because it's the last local checkpoint.
#   1. tsc-ratchet: typecheck count must not exceed the baseline in
#      .tsc-baseline.json. Lets the legacy pile of errors stay (we'll
#      chip them away over time) but blocks any NEW error a push would
#      introduce. To lower the ratchet after fixing some:
#         npm run tsc:rebaseline
#   2. tests for files changed since origin/main (--changedSince)
#
# If any check fails the push aborts. Fix and retry.
#
# Bypass: `git push --no-verify` (only when you really know).

set -e

# 1. tsc ratchet — count current errors, compare to baseline.
echo "[pre-push] typecheck (ratchet vs .tsc-baseline.json)…"
ACTUAL=$(npx tsc --noEmit 2>&1 | grep -c "error TS" || true)
BASELINE=$(node -e "console.log(require('./.tsc-baseline.json').errorCount)" 2>/dev/null || echo 0)

if [ "$ACTUAL" -gt "$BASELINE" ]; then
  DELTA=$((ACTUAL - BASELINE))
  echo ""
  echo "[pre-push] tsc REGRESSION: $ACTUAL errors vs baseline $BASELINE (+$DELTA new)"
  echo "           See full list: npx tsc --noEmit"
  echo "           Fix the new errors, or update baseline if intentional:"
  echo "             npm run tsc:rebaseline"
  echo ""
  exit 1
elif [ "$ACTUAL" -lt "$BASELINE" ]; then
  IMPROVED=$((BASELINE - ACTUAL))
  echo "[pre-push] tsc IMPROVED: $ACTUAL errors vs baseline $BASELINE (-$IMPROVED 🎉)"
  echo "           Lock in the win:  npm run tsc:rebaseline"
else
  echo "[pre-push] tsc held flat at $ACTUAL errors (baseline $BASELINE)."
fi

# 2. Test only what your branch actually changed since origin/main.
#    Full suite still runs in CI — this is the fast feedback gate.
echo "[pre-push] jest --changedSince=origin/main…"
npm run test:changed --silent
