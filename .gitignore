# Dependencies
node_modules/

# Expo
.expo/
dist/
web-build/

# Environment — never commit real secrets (root + any nested service)
.env
.env.local
.env.staging
.env.*.local
.env.contabo
apps/**/.env
apps/**/.env.local

# Developer env handoff doc — contains real secrets (Contabo/API/SSH + keys).
# Share over a secure channel only; must NEVER be committed.
ENV_SETUP.md

# Firebase Admin SDK service account — private key, must NEVER be committed.
# Lives at the project root for local builds; on EC2 it lives at
# /home/ubuntu/bravo/firebase-service-account.json (mounted into the
# messenger-service container).
*firebase-adminsdk*.json
firebase-service-account.json
apps/**/.env.*.local

# SSH keys / cloud credentials — never commit private keys
*.pem
*.key
*.p12
.ssh/

# Personal / local tool state (scheduled tasks, local overrides)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Internal review documents — never auto-publish
*.docx

# Supabase CLI local state (generated)
supabase/.temp/
supabase/.branches/

# Native build output
android/
ios/
android.backup-*/
ios.backup-*/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/

# Sensitive documents
*.pdf

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Bravo device / crash logs captured during testing — may contain
# plaintext message bodies, JWTs, or device identifiers; never commit.
bravo-log*.txt
bravo-log*.log
bravo_log*.txt
bravo_log*.log
bravosecure_logs.txt

# Local AWS / cloud credential dumps — never commit.
Aws creds
aws-creds*
aws_creds*

# Local working notes / private audit trackers — these are personal
# scratchpads, not project artifacts. Anything that becomes shared
# documentation belongs in docs/ and should be committed explicitly.
BRAVO_LITE_AUDIT_TRACKER.md
lesson.md

# TypeScript
*.tsbuildinfo

# User-uploaded files (KYC docs, agent uploads — never commit)
apps/auth-service/uploads/

# Next.js build cache
apps/ops-console/.next/
apps/**/.next/

# Local AWS staging notes (contains IPs / personal staging info)
AWS_STAGING.md
STAGING_API_TESTING.md
SESSION_SUMMARY.md
.aider*

# Jest coverage output
coverage/
